# === Backend Environment Variables ===

# Database (Render provides DATABASE_URL automatically when you link a PostgreSQL service)
DATABASE_URL=jdbc:postgresql://host:5432/parkhere
DB_USERNAME=parkhere
DB_PASSWORD=parkhere

# JWT (MUST change for production — generate a random 64+ char string)
JWT_SECRET=your-super-secret-key-at-least-256-bits-long-change-this-in-production

# CORS (your frontend URL on Render)
CORS_ORIGINS=https://parkhere-frontend.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=345298825311-1vpn0jdmbulhrfnhoor2incsnnlgmfs6.apps.googleusercontent.com

# SMTP (for password reset emails — optional for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Password reset link base URL
RESET_BASE_URL=https://parkhere-frontend.onrender.com/reset-password

# === Frontend Environment Variables ===

# Backend API URL (the Render backend URL)
NEXT_PUBLIC_API_URL=https://parkhere-backend.onrender.com/api/v1
NEXT_PUBLIC_API_BASE=https://parkhere-backend.onrender.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=345298825311-1vpn0jdmbulhrfnhoor2incsnnlgmfs6.apps.googleusercontent.com
